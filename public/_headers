# Cloudflare Workers Static Assets reads this file (same syntax as Pages) to
# set response headers per path. Deployed via wrangler.jsonc -> assets.dist.

# Content-hashed build output: the filename changes whenever the bytes do, so
# these are safe to cache forever. Without this, Cloudflare's default of
# `max-age=0, must-revalidate` makes the browser revalidate every immutable
# asset on every load.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Service worker + app shell must ALWAYS revalidate so a freshly deployed build
# is detected and the in-app "Update available" prompt fires. This matches
# Cloudflare's current default but is pinned here so it can't silently regress.
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate
